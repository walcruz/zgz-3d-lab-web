---
import { SITE_TITLE } from '../consts';
---

<div id="parallax-bg" aria-hidden="true"></div>
<header>
	<div class="shell">
		<a class="brand" href="/">
			<img src="/gpt-logo2.png" alt="Logo ZGZ 3D Lab" width="42" height="42" />
			<span>{SITE_TITLE}</span>
		</a>
		<nav aria-label="Navegacion principal">
			<a href="/#productos">Productos</a>
			<a href="/#trabajos">Trabajos</a>
			<a
				class="cta"
				href="https://www.instagram.com/zgz3dlab/"
				target="_blank"
				rel="noreferrer"
				aria-label="Abrir Instagram de ZGZ 3D Lab"
			>
				Instagram
			</a>
		</nav>
	</div>
</header>
<script is:inline>
	const bg = document.getElementById('parallax-bg');
	if (bg instanceof HTMLElement) {
		let ticking = false;
		window.addEventListener(
			'scroll',
			() => {
				if (ticking) return;
				ticking = true;
				requestAnimationFrame(() => {
					const offset = window.scrollY * 0.08;
					bg.style.transform = `translateY(${offset}px)`;
					ticking = false;
				});
			},
			{ passive: true },
		);
	}
</script>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(12px);
		background: rgba(6, 8, 8, 0.8);
		border-bottom: 1px solid rgba(184, 230, 0, 0.22);
	}
	.shell {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0.85rem 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		margin: 0;
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: #f5f7f8;
		text-transform: uppercase;
		text-decoration: none;
	}
	.brand img {
		width: 42px;
		height: 42px;
		border-radius: 50%;
		box-shadow: 0 0 0 1px rgba(184, 230, 0, 0.4), 0 0 20px rgba(184, 230, 0, 0.16);
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}
	nav a {
		padding: 0.5rem 0.8rem;
		font-size: 0.95rem;
		color: #d8dedb;
		border-radius: 999px;
		text-decoration: none;
		transition: background-color 180ms ease, color 180ms ease;
	}
	nav a:hover {
		background: rgba(184, 230, 0, 0.12);
		color: #ffffff;
	}
	nav a.cta {
		background: linear-gradient(120deg, #b8e600, #d9ff52);
		color: #050700;
		border: 1px solid rgba(217, 255, 82, 0.75);
		font-weight: 800;
	}
	nav a.cta:hover {
		background: linear-gradient(120deg, #d1ff32, #e5ff84);
		color: #050700;
	}
	@media (max-width: 720px) {
		.shell {
			align-items: flex-start;
			flex-direction: column;
		}
		nav {
			flex-wrap: wrap;
		}
	}
</style>
